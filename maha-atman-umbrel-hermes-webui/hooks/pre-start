#!/bin/bash
# hooks/pre-start — runs before the app container starts
# Copies Hermes Agent Python source from the agent container if not already present.
# This is needed because /opt/hermes is baked into the agent image, not a bind mount.

AGENT_SRC="${APP_DATA_DIR}/data/hermes-agent-src"

if [ ! -f "$AGENT_SRC/pyproject.toml" ]; then
  echo "[hermes-webui] Agent source not found at $AGENT_SRC — copying from hermes-agent container..."
  mkdir -p "$AGENT_SRC"
  docker cp hermes-agent_web_1:/opt/hermes "$AGENT_SRC"
  if [ $? -eq 0 ]; then
    echo "[hermes-webui] Agent source copied successfully."
  else
    echo "[hermes-webui] WARNING: Failed to copy agent source. WebUI may not start correctly."
    echo "[hermes-webui] Ensure hermes-agent app is running, then restart this app."
  fi
else
  echo "[hermes-webui] Agent source already present at $AGENT_SRC"
fi
